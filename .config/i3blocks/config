command=~/.local/bin/statusbar/$BLOCK_NAME
separator_block_width=15
markup=pango

## Quick Launcher

[nautilus]
full_text=
command=echo button=$BLOCK_BUTTON x=$BLOCK_X y=$BLOCK_Y | nautilus --no-desktop &
align=left
color=#E4E49E

[sublime]
full_text=
command=echo button=$BLOCK_BUTTON x=$BLOCK_X y=$BLOCK_Y | subl --class=subl &
align=left
color=#E4E49E

[steam]
full_text=
command=echo button=$BLOCK_BUTTON x=$BLOCK_X y=$BLOCK_Y | steam &
align=left
color=#E4E49E

[spotify]
full_text=
command=echo button=$BLOCK_BUTTON x=$BLOCK_X y=$BLOCK_Y | spotify &
align=left
color=#E4E49E

[spacer]
full_text=

